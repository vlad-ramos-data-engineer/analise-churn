# ==========================================
# 1. Ambientes Virtuais e Dependências
# ==========================================
venv/
.venv/
env/
.env/
Pipfile.lock
poetry.lock

# ==========================================
# 2. Arquivos Temporários do Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# ==========================================
# 3. Dados
# ==========================================
# Por padrão, não versionar dumps/extrações de dados locais
*.csv
*.tsv
*.dat
*.parquet
*.json
*.sqlite
*.db
data/*
!data/.gitkeep
# Exceção: base fictícia de exemplo, versionada para o projeto ser reprodutível
!data/clientes_churn.csv

# ==========================================
# 4. Credenciais e Variáveis de Ambiente
# ==========================================
.env
.env.*
*.pem
credentials.json
*service_account*.json  
gcp-credentials.json
.kaggle/kaggle.json

# ==========================================
# 5. Notebooks e Machine Learning
# ==========================================
.ipynb_checkpoints/
# Modelos treinados podem ser pesados, melhor salvar no storage
*.pkl
*.model
*.h5
*.pb

# ==========================================
# 6. IDEs e Sistema Operacional
# ==========================================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
